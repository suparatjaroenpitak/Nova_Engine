{
  "version": "1.0",
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfile": "backend/docker/Nova.Api.Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ALWAYS",
    "healthcheckPath": "/api/v1/auth/me",
    "healthcheckTimeout": 300
  }
}
