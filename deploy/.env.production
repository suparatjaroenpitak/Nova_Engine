# Nova Engine — Production Environment Template
# Copy to .env and fill in your values

# ── PostgreSQL ──────────────────────────────────────────────────────
# Use: Neon (free) or your own Postgres
POSTGRES_USER=nova
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=nova_engine
POSTGRES_PORT=5432
ConnectionStrings__Postgres=Host=postgres;Port=5432;Database=nova_engine;Username=nova;Password=CHANGE_ME_STRONG_PASSWORD

# ── Redis (optional — Upstash Redis free tier) ──────────────────────
ConnectionStrings__Redis=redis:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASS

# ── JWT ─────────────────────────────────────────────────────────────
Jwt__SigningKey=CHANGE_ME_to_a_64_char_hex_string_0123456789abcdef0123456789abcdef
Jwt__Issuer=NovaEngine
Jwt__Audience=NovaEditor

# ── Asset Storage (MinIO / S3-compatible) ───────────────────────────
# Local MinIO: localhost:9000  |  Backblaze B2: s3.us-west-004.backblazeb2.com
MinIO__Endpoint=minio:9000
MinIO__AccessKey=CHANGE_ME
MinIO__SecretKey=CHANGE_ME
MinIO__Bucket=nova-assets
MinIO__Secure=false

# ── CORS ────────────────────────────────────────────────────────────
Cors__AllowedOrigins__0=https://nova-engine.example.com

# ── Admin Seed ──────────────────────────────────────────────────────
Seed__CreateAdmin=true
Seed__AdminEmail=admin@nova.local
Seed__AdminPassword=CHANGE_ME_ADMIN_PASS

# ── GPU (Phase 10 — LocalStub for now) ──────────────────────────────
Gpu__Provider=LocalStub
Gpu__ServiceUrl=http://gpu:8000

# ── AI (Phase 9 — LocalStub for now) ────────────────────────────────
Ai__Provider=LocalStub
Ai__OpenAi__ApiKey=

# ── OAuth (Google / GitHub — optional) ──────────────────────────────
OAuth__Google__ClientId=
OAuth__Google__ClientSecret=
OAuth__GitHub__ClientId=
OAuth__GitHub__ClientSecret=
