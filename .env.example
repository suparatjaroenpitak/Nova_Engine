# ============================================================================
# Nova Engine — environment template. Copy to ".env" and adjust.
# docker-compose.yml reads these directly.
# ============================================================================

# ---- PostgreSQL ----
POSTGRES_USER=nova
POSTGRES_PASSWORD=nova_postgres_dev
POSTGRES_DB=nova_engine
POSTGRES_PORT=5432

# ---- Connection strings (used by the API) ----
ConnectionStrings__Postgres=Host=postgres;Port=5432;Database=nova_engine;Username=nova;Password=nova_postgres_dev
ConnectionStrings__Redis=redis:6379

# ---- JWT ----
Jwt__Issuer=NovaEngine
Jwt__Audience=NovaEditor
Jwt__SigningKey=CHANGE_ME_to_a_long_random_secret_at_least_32_chars_long_123456
Jwt__AccessTokenMinutes=60
Jwt__RefreshTokenDays=7

# ---- OAuth (fill to enable Google / GitHub login) ----
OAuth__Google__ClientId=
OAuth__Google__ClientSecret=
OAuth__GitHub__ClientId=
OAuth__GitHub__ClientSecret=

# ---- MinIO (S3-compatible object storage) ----
MinIO__Endpoint=minio:9000
MinIO__AccessKey=minio
MinIO__SecretKey=minio12345
MinIO__Bucket=nova-assets
MinIO__Secure=false

# ---- API ----
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5080
Cors__AllowedOrigins__0=http://localhost:5173

# ---- GPU service (Phase 10) ----
Gpu__ServiceUrl=http://gpu:8000
Gpu__Provider=LocalStub

# ---- AI (Phase 9) ----
Ai__Provider=LocalStub
Ai__OpenAi__ApiKey=
